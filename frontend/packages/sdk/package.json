{
  "name": "@kubuno/sdk",
  "version": "0.1.1",
  "description": "Kubuno module SDK — the stable surface (registries, stores, hooks, i18n, widgets) that runtime-loaded modules build against. Provided by the host at runtime via the import map; this package ships the type surface.",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/kubuno/core/tree/main/frontend/packages/sdk",
  "repository": { "type": "git", "url": "git+https://github.com/kubuno/core.git", "directory": "frontend/packages/sdk" },
  "type": "module",
  "sideEffects": false,
  "files": ["index.js", "types", "README.md"],
  "types": "./types/sdk/index.d.ts",
  "exports": {
    ".": { "types": "./types/sdk/index.d.ts", "import": "./index.js" },
    "./*": { "types": "./types/sdk/*.d.ts", "import": "./index.js" }
  },
  "publishConfig": { "access": "public" },
  "dependencies": {
    "axios": "^1.7.0",
    "yjs": "^13.6.0",
    "y-protocols": "^1.0.6"
  },
  "peerDependencies": {
    "@kubuno/ui": "^0.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "@tanstack/react-query": "^5.0.0",
    "zustand": "^5.0.0",
    "i18next": "^26.0.0",
    "react-i18next": "^17.0.0",
    "date-fns": "^3.0.0 || ^4.0.0",
    "lucide-react": "^1.17.0"
  }
}
