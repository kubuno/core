{
  "id": "kubuno-onedrive",
  "name": "Kubuno OneDrive",
  "color_scheme": "light",
  "version": "1.1.0",
  "theme_api_version": 1,
  "vars": {
    "--color-primary": "#0078d4",
    "--color-primary-hover": "#106ebe",
    "--color-primary-light": "#cfe4fa",
    "--color-white": "#ffffff",
    "--color-surface-0": "#ffffff",
    "--color-surface-1": "#faf9f8",
    "--color-surface-2": "#f3f2f1",
    "--color-surface-3": "#edebe9",
    "--color-search-bg": "#f3f2f1",
    "--color-text-primary": "#323130",
    "--color-text-secondary": "#605e5c",
    "--color-text-tertiary": "#a19f9d",
    "--color-text-nav-active": "#0f548c",
    "--color-border": "#edebe9",
    "--color-border-strong": "#c8c6c4",
    "--color-danger": "#d13438",
    "--color-danger-light": "#fde7e9",
    "--color-success": "#107c10",
    "--color-success-light": "#dff6dd",
    "--color-warning": "#ffb900",
    "--color-warning-light": "#fff4ce",
    "--body-bg": "#f3f2f1",
    "--scrollbar-thumb": "#c8c6c4",
    "--scrollbar-thumb-hover": "#a19f9d",
    "--color-headerbar": "#0364b8",
    "--color-headerbar-2": "#005a9e",
    "--font-family-sans": "\"Segoe UI\", \"Segoe UI Web (West European)\", -apple-system, BlinkMacSystemFont, Roboto, \"Helvetica Neue\", sans-serif",
    "--font-family-mono": "\"Cascadia Code\", \"Cascadia Mono\", Consolas, ui-monospace, monospace",
    "--radius-sm": "2px",
    "--radius": "4px",
    "--radius-md": "4px",
    "--radius-lg": "6px",
    "--radius-xl": "8px",
    "--radius-2xl": "10px",
    "--kbn-ws-panel": "#faf9f8",
    "--kbn-ws-toolbar": "#f3f2f1",
    "--kbn-ws-border": "#edebe9",
    "--kbn-ws-text": "#323130",
    "--kbn-ws-text-dim": "#605e5c",
    "--kbn-ws-hover": "#f3f2f1",
    "--kbn-ws-active": "#cfe4fa",
    "--kbn-ws-status": "#faf9f8",
    "--kbn-office-tabstrip": "#0364b8",
    "--kbn-office-tabstrip-text": "#ffffff",
    "--kbn-office-strip-hover": "rgba(255, 255, 255, 0.15)",
    "--kbn-office-tab-active-text": "#0078d4",
    "--kbn-office-item-active-text": "#0078d4",
    "--kbn-office-item-active-bg": "#cfe4fa",
    "--kbn-office-file-accent": "#0078d4"
  },
  "global": {
    "css": "global.css"
  }
}