{
  "id": "kubuno-macos",
  "name": "Kubuno macOS",
  "color_scheme": "light",
  "version": "1.6.0",
  "theme_api_version": 1,
  "vars": {
    "--color-primary": "#007aff",
    "--color-primary-hover": "#0a6fe0",
    "--color-primary-light": "#dbeafe",
    "--color-white": "#ffffff",
    "--color-surface-0": "#ffffff",
    "--color-surface-1": "#f5f5f7",
    "--color-surface-2": "#ececef",
    "--color-surface-3": "#e1e1e6",
    "--color-search-bg": "#e8e8ec",
    "--color-text-primary": "#1d1d1f",
    "--color-text-secondary": "#6e6e73",
    "--color-text-tertiary": "#8e8e93",
    "--color-text-nav-active": "#0a3d8f",
    "--color-border": "#d6d6db",
    "--color-border-strong": "#c2c2c8",
    "--color-danger": "#ff3b30",
    "--color-danger-light": "#ffe5e3",
    "--color-success": "#34c759",
    "--color-success-light": "#e4f8ea",
    "--color-warning": "#ff9f0a",
    "--color-warning-light": "#fff2dd",
    "--body-bg": "#e9e9ed",
    "--scrollbar-thumb": "#c3c3c9",
    "--scrollbar-thumb-hover": "#a3a3aa",
    "--font-family-sans": "-apple-system, BlinkMacSystemFont, \"SF Pro Text\", \"SF Pro Display\", \"Helvetica Neue\", Inter, system-ui, sans-serif",
    "--font-family-mono": "\"SF Mono\", ui-monospace, Menlo, Monaco, \"DM Mono\", monospace",
    "--radius-sm": "6px",
    "--radius": "8px",
    "--radius-md": "8px",
    "--radius-lg": "12px",
    "--radius-xl": "16px",
    "--radius-2xl": "20px",
    "--kbn-ws-panel": "#f5f5f7",
    "--kbn-ws-toolbar": "#ececef",
    "--kbn-ws-border": "#d6d6db",
    "--kbn-ws-text": "#1d1d1f",
    "--kbn-ws-text-dim": "#6e6e73",
    "--kbn-ws-hover": "#e9e9ed",
    "--kbn-ws-status": "#f5f5f7",
    "--kbn-office-tabstrip": "#ececef",
    "--kbn-office-tabstrip-text": "#1d1d1f",
    "--kbn-office-strip-hover": "rgba(0, 0, 0, 0.06)"
  },
  "global": {
    "css": "global.css"
  }
}