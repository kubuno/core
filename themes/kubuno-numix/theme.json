{
  "id": "kubuno-numix",
  "name": "Kubuno Numix",
  "color_scheme": "light",
  "version": "1.1.0",
  "theme_api_version": 1,
  "vars": {
    "--color-primary": "#d64937",
    "--color-primary-hover": "#c13d2c",
    "--color-primary-light": "#f8e2de",
    "--color-white": "#ffffff",
    "--color-surface-0": "#ffffff",
    "--color-surface-1": "#f6f6f6",
    "--color-surface-2": "#ececec",
    "--color-surface-3": "#e0e0e0",
    "--color-search-bg": "#3a3d42",
    "--color-text-primary": "#2d2d2d",
    "--color-text-secondary": "#5c5c5c",
    "--color-text-tertiary": "#8a8a8a",
    "--color-text-nav-active": "#b03a2e",
    "--color-border": "#dcdcdc",
    "--color-border-strong": "#c4c4c4",
    "--color-danger": "#c0392b",
    "--color-danger-light": "#f6e1de",
    "--color-success": "#27ae60",
    "--color-success-light": "#e3f6ea",
    "--color-warning": "#f39c12",
    "--color-warning-light": "#fdf0db",
    "--body-bg": "#e4e4e4",
    "--scrollbar-thumb": "#c4c4c4",
    "--scrollbar-thumb-hover": "#a8a8a8",
    "--color-headerbar": "#2d2d2d",
    "--color-headerbar-2": "#34373b",
    "--font-family-sans": "Roboto, \"Noto Sans\", Cantarell, Ubuntu, \"Droid Sans\", Inter, system-ui, sans-serif",
    "--font-family-mono": "\"Roboto Mono\", ui-monospace, \"DejaVu Sans Mono\", Menlo, monospace",
    "--radius-sm": "2px",
    "--radius": "3px",
    "--radius-md": "3px",
    "--radius-lg": "4px",
    "--radius-xl": "6px",
    "--radius-2xl": "8px",
    "--kbn-ws-panel": "#f6f6f6",
    "--kbn-ws-toolbar": "#ececec",
    "--kbn-ws-border": "#dcdcdc",
    "--kbn-ws-text": "#2d2d2d",
    "--kbn-ws-text-dim": "#757575",
    "--kbn-ws-hover": "#ececec",
    "--kbn-ws-active": "#f8e2de",
    "--kbn-ws-status": "#f6f6f6",
    "--kbn-office-tabstrip": "#2d2d2d",
    "--kbn-office-tabstrip-text": "#ffffff",
    "--kbn-office-strip-hover": "rgba(255, 255, 255, 0.12)",
    "--kbn-office-tab-active-text": "#d64937",
    "--kbn-office-item-active-text": "#d64937",
    "--kbn-office-item-active-bg": "rgba(214, 73, 55, 0.13)",
    "--kbn-office-file-accent": "#d64937"
  },
  "global": {
    "css": "global.css"
  }
}